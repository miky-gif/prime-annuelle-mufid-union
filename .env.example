# Copiez ce fichier en ".env" et adaptez les valeurs.

# Port d'ecoute du serveur
PORT=3001

# Environnement : "development" ou "production"
NODE_ENV=development

# Secret utilise pour signer les sessions (chaine longue et aleatoire).
# Generer par ex. avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=changez-moi-par-une-chaine-aleatoire-longue

# Identifiants de l'espace administrateur (tableau des participants + export).
# Le mot de passe est stocke ici en clair UNIQUEMENT pour la config locale.
# En production, privilegiez une variable d'environnement injectee par l'hote.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez-ce-mot-de-passe

# Mettre a "true" si l'app est servie derriere HTTPS (cookies "secure").
# Laisser "false" en local (http://localhost).
TRUST_PROXY_HTTPS=false

# ---------------------------------------------------------------------------
# Firebase (base de donnees Firestore)
# ---------------------------------------------------------------------------
# Console Firebase > Parametres du projet > Comptes de service >
#   "Generer une nouvelle cle privee" : telecharge un fichier JSON.
#
# METHODE 1 (recommandee) : placez ce fichier dans le projet (ex. serviceAccountKey.json)
# et indiquez son chemin ici. Le fichier est ignore par git (voir .gitignore).
FIREBASE_KEY_PATH=serviceAccountKey.json
#
# METHODE 2 (variables separees) : decommentez et renseignez ces trois lignes
# a la place de FIREBASE_KEY_PATH. Conservez les guillemets autour de la cle
# privee et gardez les "\n" tels quels.
# FIREBASE_PROJECT_ID=mon-projet
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@mon-projet.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# Nom de la collection Firestore (optionnel, defaut : participations)
# FIREBASE_COLLECTION=participations
